# PRODUCTION ENVIRONMENT VARIABLES
# WARNING: Never commit this file with real values to version control

# Database Configuration
DATABASE_URL="postgresql://username:password@host:5432/database"
POSTGRES_DB=restauranthub
POSTGRES_USER=restauranthub_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Redis Configuration
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
REDIS_CACHE_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
REDIS_QUEUE_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Service Discovery
CONSUL_HOST=your-consul-host
CONSUL_PORT=8500

# API Gateway
API_GATEWAY_PORT=3000
GATEWAY_SECRET=GENERATE_STRONG_SECRET_BASE64

# Authentication - GENERATE THESE WITH: openssl rand -base64 64
JWT_SECRET=GENERATE_STRONG_SECRET_BASE64
JWT_REFRESH_SECRET=GENERATE_STRONG_SECRET_BASE64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session Management
SESSION_SECRET=GENERATE_STRONG_SECRET_BASE64

# AWS Services (Production)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=your-production-bucket

# Email Configuration (Production)
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your_email_password

# SMS Configuration (Production)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Monitoring
PROMETHEUS_URL=http://your-prometheus:9090
GRAFANA_URL=http://your-grafana:3000

# Environment
NODE_ENV=production
LOG_LEVEL=info

# Frontend URLs
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_SOCKET_URL=wss://api.yourdomain.com

# Demo credentials (only for staging environments)
# DEMO_ADMIN_EMAIL=admin@yourdomain.com
# DEMO_ADMIN_PASSWORD=SECURE_DEMO_PASSWORD
# DEMO_RESTAURANT_EMAIL=restaurant@yourdomain.com
# DEMO_RESTAURANT_PASSWORD=SECURE_DEMO_PASSWORD
# DEMO_EMPLOYEE_EMAIL=employee@yourdomain.com
# DEMO_EMPLOYEE_PASSWORD=SECURE_DEMO_PASSWORD
# DEMO_VENDOR_EMAIL=vendor@yourdomain.com
# DEMO_VENDOR_PASSWORD=SECURE_DEMO_PASSWORD

# Rate Limiting
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Security
ENABLE_CSRF=true
ENABLE_SECURITY_HEADERS=true
TRUST_PROXY=true