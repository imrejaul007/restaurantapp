# ================================
# RestaurantHub Environment Template
# ================================
#
# SECURITY WARNING: Never commit real secrets to version control!
# This is a template file showing required environment variables.
# Copy this to .env and update with your actual values.

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/restauranthub"
POSTGRES_DB=restauranthub
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_strong_password

# Redis Configuration (Optional - disable if not using Redis)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@localhost:6379

# Service Discovery (Optional - for microservices)
CONSUL_HOST=localhost
CONSUL_PORT=8500

# API Configuration
API_GATEWAY_PORT=3000
API_PORT=3001
GATEWAY_SECRET=generate_random_32_byte_base64_string

# Authentication Secrets - CRITICAL: Generate secure random values!
# Use: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here_64_bytes_base64
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_64_bytes_base64
JWT_PASSWORD_RESET_SECRET=your_password_reset_secret_here_64_bytes_base64
JWT_EMAIL_VERIFICATION_SECRET=your_email_verification_secret_here_64_bytes_base64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session Management
# Use: openssl rand -base64 64
SESSION_SECRET=your_session_secret_here_64_bytes_base64

# AWS Services (Use LocalStack for development)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=restauranthub-assets

# Email Configuration (Development)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# SMS Configuration (Development)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_service_account@your-project.iam.gserviceaccount.com

# Monitoring (Optional)
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3006

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Demo Credentials (Development Only)
# WARNING: Use strong passwords even for demo accounts
DEMO_ADMIN_EMAIL=admin@yourdomain.com
DEMO_ADMIN_PASSWORD=your_secure_demo_password
DEMO_RESTAURANT_EMAIL=restaurant@yourdomain.com
DEMO_RESTAURANT_PASSWORD=your_secure_demo_password
DEMO_EMPLOYEE_EMAIL=employee@yourdomain.com
DEMO_EMPLOYEE_PASSWORD=your_secure_demo_password
DEMO_VENDOR_EMAIL=vendor@yourdomain.com
DEMO_VENDOR_PASSWORD=your_secure_demo_password

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3001

# CORS Configuration (Production)
ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com
ALLOW_NO_ORIGIN_REQUESTS=false

# Demo Account Configuration (Use environment variables for security)
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=demo-admin@example.com
NEXT_PUBLIC_DEMO_RESTAURANT_EMAIL=demo-restaurant@example.com
NEXT_PUBLIC_DEMO_EMPLOYEE_EMAIL=demo-employee@example.com
NEXT_PUBLIC_DEMO_VENDOR_EMAIL=demo-vendor@example.com

# =================================
# Security Checklist:
# =================================
# 1. ✅ Generate unique JWT secrets using: openssl rand -base64 64
# 2. ✅ Generate unique session secret using: openssl rand -base64 64
# 3. ✅ Generate unique gateway secret using: openssl rand -base64 32
# 4. ✅ Use strong database passwords
# 5. ✅ Never commit .env to version control
# 6. ✅ Rotate secrets regularly in production
# 7. ✅ Use environment-specific .env files (.env.production, .env.staging)
# 8. ✅ Enable HTTPS in production
# 9. ✅ Set NODE_ENV=production in production
# 10. ✅ Review and audit all environment variables