# Development Environment Variables
# Copy this file to .env.local and fill in your values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/restauranthub"

# Redis
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="your-32-char-minimum-secret-here"
JWT_ADMIN_SECRET="your-admin-secret-32-chars-minimum"

# API Keys
SENDGRID_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Sentry
SENTRY_DSN=""

# Node Environment
NODE_ENV="development"
PORT=3000

# RTMN Commerce Memory
INTENT_CAPTURE_URL="https://rez-intent-graph.onrender.com"
