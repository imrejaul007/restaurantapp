# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/restauranthub"
POSTGRES_DB=restauranthub
POSTGRES_USER=restauranthub
POSTGRES_PASSWORD=restauranthub_secret

# Redis Configuration  
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_CACHE_PASSWORD=redis_cache_secret
REDIS_QUEUE_PASSWORD=redis_queue_secret

# Service Discovery
CONSUL_HOST=localhost
CONSUL_PORT=8500

# API Gateway
API_GATEWAY_PORT=3000
GATEWAY_SECRET=gateway_super_secret_key

# Authentication
JWT_SECRET=super_secret_jwt_key_for_development
JWT_REFRESH_SECRET=super_secret_refresh_key_for_development
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Session Management
SESSION_SECRET=super_secret_session_key_for_development

# AWS Services (LocalStack for development)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=restauranthub-assets

# Email Configuration (Development)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=test_password

# SMS Configuration (Development)
TWILIO_ACCOUNT_SID=test_sid
TWILIO_AUTH_TOKEN=test_token
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications
FIREBASE_PROJECT_ID=restauranthub-dev
FIREBASE_PRIVATE_KEY=test_private_key
FIREBASE_CLIENT_EMAIL=test@restauranthub-dev.iam.gserviceaccount.com

# Monitoring
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3006

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3000