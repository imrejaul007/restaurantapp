{
  "name": "restopapa",
  "version": "1.0.0",
  "description": "B2B/B2C SaaS platform for restaurants",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:migrate": "npm run db:migrate --workspace=@restopapa/db",
    "db:seed": "npm run db:seed --workspace=@restopapa/db",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "redis:up": "docker-compose -f docker-compose.redis.yml up -d",
    "redis:down": "docker-compose -f docker-compose.redis.yml down",
    "perf:artillery": "cd tests/performance && artillery run artillery-config.yml",
    "perf:k6": "cd tests/performance && k6 run k6-load-test.js",
    "perf:k6:load": "cd tests/performance && k6 run --env TEST_TYPE=load k6-load-test.js",
    "perf:k6:spike": "cd tests/performance && k6 run --env TEST_TYPE=spike k6-load-test.js",
    "perf:k6:stress": "cd tests/performance && k6 run --env TEST_TYPE=stress k6-load-test.js",
    "perf:setup": "scripts/setup-redis.sh",
    "perf:all": "npm run perf:k6:load && npm run perf:k6:spike && npm run perf:k6:stress",
    "monitoring:up": "docker-compose -f docker-compose.monitoring.yml up -d",
    "monitoring:down": "docker-compose -f docker-compose.monitoring.yml down",
    "monitoring:logs": "docker-compose -f docker-compose.monitoring.yml logs -f",
    "grafana:open": "open http://localhost:3000",
    "prometheus:open": "open http://localhost:9090",
    "alerts:open": "open http://localhost:9093"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "prettier": "^3.2.4",
    "turbo": "^1.11.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.30",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/graphql": "^12.2.2",
    "@prisma/client": "^6.15.0",
    "@sentry/nextjs": "^10.11.0",
    "@sentry/node": "^10.11.0",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^21.1.7",
    "ai": "^5.0.44",
    "apollo-server-express": "^3.13.0",
    "class-sanitizer": "^1.0.1",
    "dompurify": "^3.2.6",
    "express-brute": "^1.0.1",
    "express-ipfilter": "^1.3.2",
    "express-prometheus-middleware": "^1.2.0",
    "express-slow-down": "^3.0.0",
    "express-validator": "^7.2.1",
    "graphql": "^16.11.0",
    "isomorphic-dompurify": "^2.26.0",
    "joi": "^17.13.3",
    "jsdom": "^26.1.0",
    "mime-types": "^3.0.1",
    "newrelic": "^12.25.0",
    "openai": "^5.20.3",
    "prom-client": "^13.2.0",
    "type-graphql": "^2.0.0-rc.2"
  }
}
