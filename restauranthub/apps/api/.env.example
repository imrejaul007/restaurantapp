# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/restauranthub?schema=public"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# JWT Configuration - GENERATE SECURE SECRETS FOR PRODUCTION
JWT_SECRET="your-super-secure-jwt-secret-at-least-32-characters-long-in-production"
JWT_REFRESH_SECRET="your-super-secure-refresh-secret-at-least-32-characters-long-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server Configuration
API_PORT="3000"
API_PREFIX="api/v1"
NODE_ENV="development"

# Frontend URL
FRONTEND_URL="http://localhost:3001"

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME=""
S3_ENDPOINT=""

# Payment Gateway - Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Email Configuration
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="RestaurantHub <noreply@restauranthub.com>"

# Aadhaar Verification (Production)
UIDAI_API_URL="https://api.uidai.gov.in"
UIDAI_API_KEY=""
UIDAI_CLIENT_ID=""
UIDAI_LICENSE_KEY=""
AADHAAR_ENCRYPTION_KEY="your-32-character-encryption-key-here"

# Third-party Services
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Security
BCRYPT_ROUNDS="12"
SESSION_SECRET="your-session-secret-at-least-32-characters-long"

# Monitoring
SENTRY_DSN=""
LOG_LEVEL="info"

# RTMN Commerce Memory
INTENT_CAPTURE_URL="https://rez-intent-graph.onrender.com"