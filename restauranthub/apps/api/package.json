    "razorpay": "^2.9.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.8.1",
    "stripe": "^13.0.0",
    "uuid": "^9.0.0",
    "vue": "^3.5.21",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-elasticsearch": "^0.19.0",
    "xss": "^1.0.15",
    "prom-client": "^15.1.0",
