{
  "name": "@restauranthub/api",
  "version": "1.0.0",
  "description": "RestaurantHub Backend API",
  "private": true,
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/src/main",
    "start:prod": "node dist/main",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:performance": "jest --config ./test/jest-performance.json",
    "test:verification": "jest --testPathPattern=verification",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "test:ci": "npm run test:cov && npm run test:e2e && npm run test:performance",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:deploy": "prisma migrate deploy",
    "docker:build": "docker build -t restauranthub-api .",
    "docker:run": "docker run -p 3001:3001 restauranthub-api"
  },
  "dependencies": {
    "@apollo/server": "^4.12.2",
    "@nestjs/apollo": "^13.1.0",
    "@nestjs/cache-manager": "^2.0.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.4.20",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^5.1.1",
    "@nestjs/websockets": "^10.4.20",
    "@prisma/client": "^5.8.1",
    "@types/dompurify": "^3.0.5",
    "@types/express-brute": "^1.0.6",
    "@types/sanitize-html": "^2.16.0",
    "@types/vue": "^1.0.31",
    "argon2": "^0.31.2",
    "axios": "^1.12.2",
    "bcrypt": "^5.1.0",
    "cache-manager": "^5.2.0",
    "cache-manager-redis-store": "^3.0.0",
    "class-sanitizer": "^1.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^1.40.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.11.2",
    "express-slow-down": "^2.1.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.9.0",
    "multer": "^1.4.5-lts.1",
    "nest-winston": "^1.9.0",
