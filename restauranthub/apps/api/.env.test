# Test Environment Configuration
NODE_ENV=test
API_PORT=3001
API_HOST=localhost
API_PREFIX=api/v1

# Test Database (separate from development)
DATABASE_URL_TEST="postgresql://test:test@localhost:5432/restauranthub_test?schema=public"
DATABASE_URL="postgresql://test:test@localhost:5432/restauranthub_test?schema=public"

# Test Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=15
REDIS_URL=redis://localhost:6379/15

# Test JWT Configuration
JWT_SECRET=test-super-secret-jwt-key-for-testing-only
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test-super-secret-refresh-jwt-key-for-testing-only
JWT_REFRESH_EXPIRES_IN=7d

# Test Security Configuration
RATE_LIMIT_MAX=1000
BCRYPT_ROUNDS=4
CSRF_SECRET=test-csrf-secret
API_KEY_SECRET=test-api-key-secret

# Mock Services (disable real external calls)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=test@example.com
SMTP_PASS=testpass
EMAIL_FROM="Test RestaurantHub <test@restauranthub.com>"

# Disable external integrations in tests
SENDGRID_API_KEY=test-sendgrid-key
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=test-access-key
AWS_SES_SECRET_ACCESS_KEY=test-secret-key

# Test File Storage (use local storage only)
UPLOAD_PATH=./test-uploads
MAX_FILE_SIZE=50000000
CLOUDINARY_CLOUD_NAME=test-cloud
CLOUDINARY_API_KEY=test-api-key
CLOUDINARY_API_SECRET=test-api-secret

# Test Payment Gateways (sandbox/test keys)
STRIPE_SECRET_KEY=sk_test_test-stripe-secret-key
STRIPE_PUBLIC_KEY=pk_test_test-stripe-public-key
STRIPE_WEBHOOK_SECRET=whsec_test-webhook-secret

RAZORPAY_KEY_ID=test-razorpay-key-id
RAZORPAY_KEY_SECRET=test-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=test-razorpay-webhook-secret

# Test External APIs (disabled)
GOOGLE_MAPS_API_KEY=test-google-maps-key
TWILIO_ACCOUNT_SID=test-twilio-sid
TWILIO_AUTH_TOKEN=test-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Test Monitoring (disabled)
SENTRY_DSN=
APPINSIGHTS_INSTRUMENTATIONKEY=

# Test Cache Configuration
CACHE_TTL=60
CACHE_MAX=100

# Test Feature Flags
ENABLE_SWAGGER=false
ENABLE_RATE_LIMITING=false
ENABLE_CSRF_PROTECTION=false
ENABLE_FILE_UPLOADS=true
ENABLE_REAL_TIME_FEATURES=false
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=false

# Test Debugging
DEBUG=false
LOG_LEVEL=error