generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RESTAURANT
  EMPLOYEE
  VENDOR
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
  BANNED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
  FILLED
}

enum ApplicationStatus {
  PENDING
  SUBMITTED
  REVIEWED
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DISPATCHED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PAID
  PARTIALLY_REFUNDED
}

enum OrderType {
  DELIVERY
  PICKUP
  DINE_IN
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
  RAZORPAY
}

enum FileType {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  OTHER
}

enum EmployeeTagType {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum TagStatus {
  ACTIVE
  DISPUTED
  RESOLVED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ACCESS
  APPROVE
  REJECT
  SUSPEND
  ACTIVATE
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
  UNDER_REVIEW
}

enum GroupType {
  PUBLIC
  PRIVATE
  RESTRICTED
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  phone                 String?   @unique
  passwordHash          String
  firstName             String?
  lastName              String?
  role                  UserRole
  status                UserStatus @default(ACTIVE)
  isActive              Boolean   @default(true)
  isVerified            Boolean   @default(false)
  emailVerifiedAt       DateTime?
  isAadhaarVerified     Boolean   @default(false)
  aadhaarVerificationId String?
  twoFactorEnabled      Boolean   @default(false)
  twoFactorSecret       String?
  lastLoginAt           DateTime?
  refreshToken          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  // Relations
  profile             Profile?
  restaurant          Restaurant?
  vendor              Vendor?
  employee            Employee?
  sessions            Session[]
  notifications       Notification[]
  messages            Message[]
  posts               Post[]
  comments            Comment[]
  reviews             Review[]
  auditLogs           AuditLog[]           @relation("performedBy")
  taggedEmployees     EmployeeTag[]
  resolvedDefenses    EmployeeDefense[]
  aadhaarVerification AadhaarVerification?
  userProfile         UserProfile?
  verificationAttempts VerificationAttempt[]

  // Community Relations
  forumPosts           ForumPost[]
  postComments         PostComment[]
  postLikes            PostLike[]
  commentLikes         CommentLike[]
  postBookmarks        PostBookmark[]
  postShares           PostShare[]
  postReports          PostReport[]           @relation("PostReporter")
  reviewedPostReports  PostReport[]           @relation("PostReviewer")
  commentReports       CommentReport[]        @relation("CommentReporter")
  reviewedCommentReports CommentReport[]      @relation("CommentReviewer")
  vendorSuggestions    VendorSuggestion[]     @relation("VendorSuggester")
  ratedVendorSuggestions VendorSuggestion[]   @relation("VendorSuggestionRater")
  markedVendorSuggestions VendorSuggestion[]  @relation("VendorSuggestionMarker")
  productSuggestions   ProductSuggestion[]    @relation("ProductSuggester")
  ratedProductSuggestions ProductSuggestion[] @relation("ProductSuggestionRater")
  markedProductSuggestions ProductSuggestion[] @relation("ProductSuggestionMarker")
  vendorTags           PostVendorTag[]        @relation("VendorTagger")
  productTags          PostProductTag[]       @relation("ProductTagger")
  followers            UserFollow[]           @relation("UserFollower")
  following            UserFollow[]           @relation("UserFollowing")
  createdGroups        CommunityGroup[]
  groupMemberships     GroupMember[]
  groupPosts           GroupPost[]
  sentGroupInvitations GroupInvitation[]     @relation("GroupInviter")
  receivedGroupInvitations GroupInvitation[] @relation("GroupInvitee")
  badges               UserBadge[]
  reputation           UserReputation?
  reputationHistory    ReputationHistory[]
  forumSubscriptions   ForumSubscription[]
  moderatedForums      ForumModerator[]       @relation("ModeratorUser")
  addedModerators      ForumModerator[]       @relation("ModeratorAddedBy")
  leaderboards         CommunityLeaderboard[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
}

model Profile {
  id          String    @id @default(cuid())
  userId      String    @unique
  firstName   String
  lastName    String
  avatar      String?
  bio         String?
  address     String?
  city        String?
  state       String?
  country     String?
  pincode     String?
  dateOfBirth DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Restaurant {
  id                 String             @id @default(cuid())
  userId             String             @unique
  name               String
  businessName       String?            // Alias for name for service compatibility
  description        String?
  logo               String?
  banner             String?
  cuisineType        String[]
  licenseNumber      String?            @unique
  gstNumber          String?            @unique
  fssaiNumber        String?            @unique
  panNumber          String?
  bankAccountNumber  String?
  bankName           String?
  ifscCode           String?
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  rating             Float              @default(0)
  totalReviews       Int                @default(0)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  // Relations
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  branches          Branch[]
  employees         Employee[]
  employeeTags      EmployeeTag[]
  employmentHistory EmploymentHistory[]
  jobs              Job[]
  products          Product[]           @relation("restaurantProducts")
  orders            Order[]             @relation("restaurantOrders")
  reviews           Review[]
  documents         Document[]
  analytics         Analytics[]
  subscriptions     Subscription[]
  credits           Credit[]

  @@index([userId])
  @@index([verificationStatus])
  @@index([name])
}

model Branch {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  address      String
  city         String
  state        String
  pincode      String
  phone        String
  email        String?
  managerId    String?
  latitude     Float?
  longitude    Float?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  employees  Employee[]

  @@index([restaurantId])
}

model Vendor {
  id                 String             @id @default(cuid())
  userId             String             @unique
  companyName        String
  businessName       String             // Alias for companyName for service compatibility
  description        String?
  logo               String?
  businessType       String
  gstNumber          String?            @unique
  panNumber          String?
  bankAccountNumber  String?
  bankName           String?
  ifscCode           String?
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  rating             Float              @default(0)
  totalReviews       Int                @default(0)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  // Relations
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Product[]   @relation("vendorProducts")
  orders    Order[]     @relation("vendorOrders")
  reviews   Review[]
  documents Document[]
  payouts   Payout[]
  analytics Analytics[]

  // Community Relations
  vendorSuggestions VendorSuggestion[]
  vendorTags        PostVendorTag[]

  @@index([userId])
  @@index([verificationStatus])
  @@index([companyName])
}

model Employee {
  id             String    @id @default(cuid())
  userId         String    @unique
  restaurantId   String
  branchId       String?
  employeeCode   String    @unique
  designation    String
  department     String?
  aadharNumber   String?
  aadharVerified Boolean   @default(false)
  verifiedAt     DateTime?
  salary         Float?
  joiningDate    DateTime
  relievingDate  DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant        Restaurant          @relation(fields: [restaurantId], references: [id])
  branch            Branch?             @relation(fields: [branchId], references: [id])
  applications      JobApplication[]
  documents         Document[]
  attendance        Attendance[]
  leaves            Leave[]
  tags              EmployeeTag[]
  defenses          EmployeeDefense[]
  employmentHistory EmploymentHistory[]

  @@index([userId])
  @@index([restaurantId])
  @@index([employeeCode])
}

model Job {
  id               String    @id @default(cuid())
  restaurantId     String
  title            String
  description      String
  requirements     String[]
  skills           String[]
  experienceMin    Int       @default(0)
  experienceMax    Int?
  salaryMin        Float?
  salaryMax        Float?
  location         String
  jobType          String // Full-time, Part-time, Contract
  status           JobStatus @default(DRAFT)
  validTill        DateTime
  viewCount        Int       @default(0)
  applicationCount Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id])
  applications JobApplication[]

  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
}

model JobApplication {
  id          String            @id @default(cuid())
  jobId       String
  employeeId  String
  coverLetter String?
  resume      String?
  status      ApplicationStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewNotes String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  job      Job      @relation(fields: [jobId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([jobId, employeeId])
  @@index([jobId])
  @@index([employeeId])
  @@index([status])
}

model Category {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  description  String?
  image        String?
  parentId     String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id               String        @id @default(cuid())
  vendorId         String?
  restaurantId     String?
  categoryId       String
  name             String
  slug             String
  description      String?
  images           String[]
  sku              String        @unique
  price            Float
  comparePrice     Float?
  costPrice        Float?
  quantity         Int           @default(0)
  unit             String
  minOrderQuantity Int           @default(1)
  maxOrderQuantity Int?
  gstRate          Float         @default(18)
  hsnCode          String?
  status           ProductStatus @default(ACTIVE)
  isActive         Boolean       @default(true)
  isWholesale      Boolean       @default(false)
  isBulkOnly       Boolean       @default(false)
  viewCount        Int           @default(0)
  rating           Float         @default(0)
  totalReviews     Int           @default(0)
  tags             String[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  // Relations
  vendor       Vendor?        @relation("vendorProducts", fields: [vendorId], references: [id])
  restaurant   Restaurant?    @relation("restaurantProducts", fields: [restaurantId], references: [id])
  category     Category       @relation(fields: [categoryId], references: [id])
  cartItems    CartItem[]
  orderItems   OrderItem[]
  reviews      Review[]
  priceHistory PriceHistory[]

  // Community Relations
  productSuggestions ProductSuggestion[]
  productTags        PostProductTag[]

  @@index([vendorId])
  @@index([restaurantId])
  @@index([categoryId])
  @@index([slug])
  @@index([status])
}

model Cart {
  id           String   @id @default(cuid())
  restaurantId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  items CartItem[]

  @@unique([restaurantId])
  @@index([restaurantId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  restaurantId    String
  vendorId        String?
  subtotal        Float
  gstAmount       Float
  shippingAmount  Float         @default(0)
  discountAmount  Float         @default(0)
  totalAmount     Float
  status          OrderStatus   @default(PENDING)
  paymentMethod   String?
  paymentStatus   PaymentStatus @default(PENDING)
  shippingAddress Json?
  billingAddress  Json?
  notes           String?
  invoiceNumber   String?
  invoiceUrl      String?
  trackingNumber  String?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  creditUsed      Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  restaurant    Restaurant           @relation("restaurantOrders", fields: [restaurantId], references: [id])
  vendor        Vendor?              @relation("vendorOrders", fields: [vendorId], references: [id])
  items         OrderItem[]
  payment       Payment?
  statusHistory OrderStatusHistory[]
  transactions  Transaction[]

  @@index([restaurantId])
  @@index([vendorId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  price       Float
  gstAmount   Float
  totalAmount Float
  createdAt   DateTime @default(now())

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  notes     String?
  createdBy String?
  createdAt DateTime    @default(now())

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Payment {
  id               String        @id @default(cuid())
  orderId          String        @unique
  paymentGateway   String // razorpay, stripe
  gatewayPaymentId String?
  gatewayOrderId   String?
  amount           Float
  currency         String        @default("INR")
  status           PaymentStatus @default(PENDING)
  method           String? // card, upi, netbanking
  metadata         Json?
  failureReason    String?
  refundAmount     Float?
  refundedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([gatewayPaymentId])
  @@index([status])
}

model Transaction {
  id              String   @id @default(cuid())
  orderId         String?
  restaurantId    String?
  vendorId        String?
  type            String // credit, debit, refund
  amount          Float
  balance         Float
  description     String?
  referenceNumber String?
  createdAt       DateTime @default(now())

  // Relations
  order Order? @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([restaurantId])
  @@index([vendorId])
  @@index([type])
}

model Credit {
  id               String   @id @default(cuid())
  restaurantId     String
  availableCredits Float    @default(0)
  usedCredits      Float    @default(0)
  totalCredits     Float    @default(0)
  creditLimit      Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId])
  @@index([restaurantId])
}

model Review {
  id                 String   @id @default(cuid())
  userId             String
  productId          String?
  restaurantId       String?
  vendorId           String?
  rating             Int // 1-5
  title              String?
  comment            String?
  images             String[]
  isVerifiedPurchase Boolean  @default(false)
  helpfulCount       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user       User        @relation(fields: [userId], references: [id])
  product    Product?    @relation(fields: [productId], references: [id])
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])
  vendor     Vendor?     @relation(fields: [vendorId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([restaurantId])
  @@index([vendorId])
  @@index([rating])
}

model Conversation {
  id            String    @id @default(cuid())
  participants  String[]
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  // Relations
  messages Message[]

  @@index([participants])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  attachments    String[]
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String // order, job, message, system
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
}

model Post {
  id          String    @id @default(cuid())
  userId      String
  title       String
  content     String
  images      String[]
  tags        String[]
  viewCount   Int       @default(0)
  likeCount   Int       @default(0)
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  comments Comment[]

  @@index([userId])
  @@index([isPublished])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
}

model Document {
  id                 String             @id @default(cuid())
  restaurantId       String?
  vendorId           String?
  employeeId         String?
  type               String // license, gst, fssai, pan, aadhar, contract
  name               String
  url                String
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedBy         String?
  rejectionReason    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])
  vendor     Vendor?     @relation(fields: [vendorId], references: [id])
  employee   Employee?   @relation(fields: [employeeId], references: [id])

  @@index([restaurantId])
  @@index([vendorId])
  @@index([employeeId])
  @@index([type])
  @@index([verificationStatus])
}

model Subscription {
  id           String   @id @default(cuid())
  restaurantId String
  planName     String
  features     Json
  price        Float
  billingCycle String // monthly, yearly
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean  @default(true)
  autoRenew    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([isActive])
}

model Analytics {
  id           String   @id @default(cuid())
  restaurantId String?
  vendorId     String?
  metric       String // revenue, orders, views, etc
  value        Float
  period       String // daily, weekly, monthly
  date         DateTime
  metadata     Json?
  createdAt    DateTime @default(now())

  // Relations
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])
  vendor     Vendor?     @relation(fields: [vendorId], references: [id])

  @@index([restaurantId])
  @@index([vendorId])
  @@index([metric])
  @@index([date])
}

model Payout {
  id              String    @id @default(cuid())
  vendorId        String
  amount          Float
  status          String // pending, processing, completed, failed
  method          String // bank_transfer, upi
  referenceNumber String?
  processedAt     DateTime?
  failureReason   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
}

model Attendance {
  id           String    @id @default(cuid())
  employeeId   String
  date         DateTime  @db.Date
  checkInTime  DateTime?
  checkOutTime DateTime?
  totalHours   Float?
  status       String // present, absent, late, half-day
  createdAt    DateTime  @default(now())

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

model Leave {
  id         String    @id @default(cuid())
  employeeId String
  type       String // sick, casual, earned
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     String // pending, approved, rejected
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
}

model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  oldPrice  Float
  newPrice  Float
  changedBy String?
  reason    String?
  createdAt DateTime @default(now())

  // Relations
  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  resource  String?
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  user User? @relation("performedBy", fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

model AadhaarVerification {
  id               String             @id @default(cuid())
  userId           String             @unique
  aadhaarHash      String
  encryptedAadhaar String
  verificationId   String             @unique
  status           VerificationStatus @default(PENDING)
  matchScore       Int                @default(0)
  nameMatch        Boolean            @default(false)
  dobMatch         Boolean?
  addressMatch     Boolean?
  phoneMatch       Boolean?
  verifiedAt       DateTime?
  attempts         Int                @default(0)
  lastAttemptAt    DateTime?
  expiresAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([aadhaarHash])
  @@index([status])
  @@index([verifiedAt])
}

model EmployeeTag {
  id           String          @id @default(cuid())
  employeeId   String
  restaurantId String
  taggedBy     String
  type         EmployeeTagType
  category     String // Performance, Attitude, Punctuality, etc.
  reason       String
  details      String?
  evidence     String[] // URLs to supporting documents/images
  status       TagStatus       @default(ACTIVE)
  isPublic     Boolean         @default(true)
  severity     Int             @default(1) // 1-5 scale
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  employee   Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  restaurant Restaurant        @relation(fields: [restaurantId], references: [id])
  tagger     User              @relation(fields: [taggedBy], references: [id])
  defenses   EmployeeDefense[]

  @@index([employeeId])
  @@index([restaurantId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model EmployeeDefense {
  id             String   @id @default(cuid())
  tagId          String
  employeeId     String
  response       String
  evidence       String[] // URLs to supporting documents/images
  isResolved     Boolean  @default(false)
  resolvedBy     String?
  resolutionNote String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  tag      EmployeeTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  resolver User?       @relation(fields: [resolvedBy], references: [id])

  @@index([tagId])
  @@index([employeeId])
  @@index([createdAt])
}

model EmploymentHistory {
  id           String    @id @default(cuid())
  employeeId   String
  restaurantId String
  startDate    DateTime
  endDate      DateTime?
  position     String
  department   String?
  reason       String? // Reason for leaving
  rating       Float? // Overall rating from employer
  review       String? // Employer's review
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([employeeId])
  @@index([restaurantId])
  @@index([startDate])
  @@index([endDate])
}

// Community Models

enum PostType {
  DISCUSSION
  TIP
  RECIPE
  JOB_REQUEST
  NEWS
  REVIEW
  VENDOR_REQUEST
  PRODUCT_REQUEST
  ANNOUNCEMENT
  PRODUCT_DISCUSSION
  JOB_POSTING
  JOB_SEEKING
}

enum PostVisibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum SuggestionRating {
  VERY_HELPFUL
  HELPFUL
  SOMEWHAT_HELPFUL
  NOT_HELPFUL
}

enum BadgeType {
  TOP_HELPER
  VENDOR_CONNECTOR
  COMMUNITY_BUILDER
  RECIPE_MASTER
  JOB_EXPERT
  TRENDING_CONTRIBUTOR
  VERIFIED_REVIEWER
  ACHIEVEMENT
  MILESTONE
  ACTIVITY
  ENGAGEMENT
  SPECIAL
}

enum ReputationAction {
  POST_CREATED
  COMMENT_CREATED
  LIKE_RECEIVED
  SUGGESTION_HELPFUL
  SUGGESTION_BEST
  POST_SHARED
  VENDOR_TAGGED
  BADGE_EARNED
  FOLLOWED_BY_USER
  GROUP_CREATED
}

model Forum {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  category    String
  icon        String?
  color       String?
  isActive    Boolean  @default(true)
  memberCount Int      @default(0)
  postCount   Int      @default(0)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  posts         ForumPost[]
  moderators    ForumModerator[]
  subscriptions ForumSubscription[]

  @@index([slug])
  @@index([category])
  @@index([displayOrder])
}

model ForumPost {
  id           String         @id @default(cuid())
  forumId      String
  userId       String
  title        String
  content      String
  type         PostType       @default(DISCUSSION)
  visibility   PostVisibility @default(PUBLIC)
  slug         String         @unique
  images       String[]
  attachments  String[]
  tags         String[]
  viewCount    Int            @default(0)
  likeCount    Int            @default(0)
  shareCount   Int            @default(0)
  commentCount Int            @default(0)
  isPinned     Boolean        @default(false)
  isLocked     Boolean        @default(false)
  isFeatured   Boolean        @default(false)
  isDeleted    Boolean        @default(false)
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  forum               Forum                     @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author              User                      @relation(fields: [userId], references: [id])
  comments            PostComment[]
  likes               PostLike[]
  bookmarks           PostBookmark[]
  shares              PostShare[]
  reports             PostReport[]
  vendorSuggestions   VendorSuggestion[]
  productSuggestions  ProductSuggestion[]
  taggedVendors       PostVendorTag[]
  taggedProducts      PostProductTag[]
  trendingPosts       TrendingPost[]

  @@index([forumId])
  @@index([userId])
  @@index([type])
  @@index([visibility])
  @@index([slug])
  @@index([isPinned])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([viewCount])
  @@index([likeCount])
}

model PostComment {
  id          String    @id @default(cuid())
  postId      String
  userId      String
  parentId    String?
  content     String
  likeCount   Int       @default(0)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  post      ForumPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [userId], references: [id])
  parent    PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   PostComment[] @relation("CommentReplies")
  likes     CommentLike[]
  reports   CommentReport[]

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  // Relations
  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  // Relations
  comment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model PostBookmark {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  // Relations
  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostShare {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  platform  String?
  createdAt DateTime @default(now())

  // Relations
  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model PostReport {
  id          String    @id @default(cuid())
  postId      String
  reporterId  String
  reason      String
  description String?
  status      ReportStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())

  // Relations
  post     ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User      @relation("PostReporter", fields: [reporterId], references: [id])
  reviewer User?     @relation("PostReviewer", fields: [reviewedBy], references: [id])

  @@index([postId])
  @@index([reporterId])
  @@index([status])
}

model CommentReport {
  id          String    @id @default(cuid())
  commentId   String
  reporterId  String
  reason      String
  description String?
  status      ReportStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())

  // Relations
  comment  PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter User        @relation("CommentReporter", fields: [reporterId], references: [id])
  reviewer User?       @relation("CommentReviewer", fields: [reviewedBy], references: [id])

  @@index([commentId])
  @@index([reporterId])
  @@index([status])
}

model VendorSuggestion {
  id          String            @id @default(cuid())
  postId      String
  suggestedBy String
  vendorId    String
  reason      String
  rating      SuggestionRating?
  ratedBy     String?
  ratedAt     DateTime?
  isBest      Boolean           @default(false)
  markedBy    String?
  markedAt    DateTime?
  createdAt   DateTime          @default(now())

  // Relations
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  suggester User      @relation("VendorSuggester", fields: [suggestedBy], references: [id])
  vendor    Vendor    @relation(fields: [vendorId], references: [id])
  rater     User?     @relation("VendorSuggestionRater", fields: [ratedBy], references: [id])
  marker    User?     @relation("VendorSuggestionMarker", fields: [markedBy], references: [id])

  @@unique([postId, suggestedBy, vendorId])
  @@index([postId])
  @@index([vendorId])
  @@index([suggestedBy])
}

model ProductSuggestion {
  id          String            @id @default(cuid())
  postId      String
  suggestedBy String
  productId   String
  reason      String
  rating      SuggestionRating?
  ratedBy     String?
  ratedAt     DateTime?
  isBest      Boolean           @default(false)
  markedBy    String?
  markedAt    DateTime?
  createdAt   DateTime          @default(now())

  // Relations
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  suggester User      @relation("ProductSuggester", fields: [suggestedBy], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  rater     User?     @relation("ProductSuggestionRater", fields: [ratedBy], references: [id])
  marker    User?     @relation("ProductSuggestionMarker", fields: [markedBy], references: [id])

  @@unique([postId, suggestedBy, productId])
  @@index([postId])
  @@index([productId])
  @@index([suggestedBy])
}

model PostVendorTag {
  id        String   @id @default(cuid())
  postId    String
  vendorId  String
  taggedBy  String
  createdAt DateTime @default(now())

  // Relations
  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  vendor Vendor    @relation(fields: [vendorId], references: [id])
  tagger User      @relation("VendorTagger", fields: [taggedBy], references: [id])

  @@unique([postId, vendorId])
  @@index([postId])
  @@index([vendorId])
}

model PostProductTag {
  id        String   @id @default(cuid())
  postId    String
  productId String
  taggedBy  String
  createdAt DateTime @default(now())

  // Relations
  post    ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  product Product   @relation(fields: [productId], references: [id])
  tagger  User      @relation("ProductTagger", fields: [taggedBy], references: [id])

  @@unique([postId, productId])
  @@index([postId])
  @@index([productId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  // Relations
  follower  User @relation("UserFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model CommunityGroup {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  isPrivate   Boolean  @default(false)
  createdBy   String
  memberCount Int      @default(1)
  postCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  creator     User                   @relation(fields: [createdBy], references: [id])
  members     GroupMember[]
  posts       GroupPost[]
  invitations GroupInvitation[]

  @@index([slug])
  @@index([createdBy])
  @@index([isPrivate])
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member") // member, moderator, admin
  joinedAt  DateTime @default(now())

  // Relations
  group CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model GroupPost {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  content   String
  images    String[]
  createdAt DateTime @default(now())

  // Relations
  group  CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author User           @relation(fields: [userId], references: [id])

  @@index([groupId])
  @@index([userId])
}

model GroupInvitation {
  id         String    @id @default(cuid())
  groupId    String
  inviterId  String
  inviteeId  String
  status     String    @default("pending") // pending, accepted, declined
  respondedAt DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  group   CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter User           @relation("GroupInviter", fields: [inviterId], references: [id])
  invitee User           @relation("GroupInvitee", fields: [inviteeId], references: [id])

  @@unique([groupId, inviteeId])
  @@index([groupId])
  @@index([inviteeId])
}

model UserBadge {
  id          String    @id @default(cuid())
  userId      String
  badgeType   BadgeType
  title       String
  description String
  icon        String?
  earnedAt    DateTime  @default(now())
  isVisible   Boolean   @default(true)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
  @@index([userId])
  @@index([badgeType])
}

model UserReputation {
  id           String   @id @default(cuid())
  userId       String   @unique
  totalPoints  Int      @default(0)
  level        Int      @default(1)
  postsCreated Int      @default(0)
  commentsCreated Int   @default(0)
  likesReceived Int     @default(0)
  sharesReceived Int    @default(0)
  helpfulSuggestions Int @default(0)
  bestSuggestions Int    @default(0)
  badgeCount   Int      @default(0)
  updatedAt    DateTime @updatedAt

  // Relations
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reputationHistory  ReputationHistory[]

  @@index([userId])
  @@index([totalPoints])
  @@index([level])
}

model ReputationHistory {
  id            String          @id @default(cuid())
  userId        String
  action        ReputationAction
  points        Int
  description   String?
  relatedId     String?         // postId, commentId, etc.
  relatedType   String?         // post, comment, suggestion, etc.
  createdAt     DateTime        @default(now())

  // Relations
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ReputationHistory_user_fkey")
  reputation UserReputation  @relation(fields: [userId], references: [userId], map: "ReputationHistory_reputation_fkey")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ForumSubscription {
  id        String   @id @default(cuid())
  userId    String
  forumId   String
  createdAt DateTime @default(now())

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)

  @@unique([userId, forumId])
  @@index([userId])
  @@index([forumId])
}

model ForumModerator {
  id        String   @id @default(cuid())
  userId    String
  forumId   String
  addedBy   String
  addedAt   DateTime @default(now())

  // Relations
  user      User  @relation("ModeratorUser", fields: [userId], references: [id], onDelete: Cascade)
  forum     Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  addedByUser User  @relation("ModeratorAddedBy", fields: [addedBy], references: [id])

  @@unique([userId, forumId])
  @@index([userId])
  @@index([forumId])
}

model TrendingPost {
  id           String   @id @default(cuid())
  postId       String
  score        Float
  period       String   // daily, weekly, monthly
  date         DateTime @db.Date
  viewScore    Float    @default(0)
  likeScore    Float    @default(0)
  commentScore Float    @default(0)
  shareScore   Float    @default(0)
  createdAt    DateTime @default(now())

  // Relations
  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, period, date])
  @@index([postId])
  @@index([period])
  @@index([date])
  @@index([score])
}

model TrendingTag {
  id         String   @id @default(cuid())
  tag        String
  score      Float
  postCount  Int      @default(0)
  period     String   // daily, weekly, monthly
  date       DateTime @db.Date
  createdAt  DateTime @default(now())

  @@unique([tag, period, date])
  @@index([tag])
  @@index([period])
  @@index([date])
  @@index([score])
}

model CommunityLeaderboard {
  id       String   @id @default(cuid())
  userId   String
  category String   // overall, posts, comments, helpful_suggestions, etc.
  period   String   // weekly, monthly, yearly
  rank     Int
  score    Float
  date     DateTime @db.Date
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period, date])
  @@index([userId])
  @@index([category])
  @@index([period])
  @@index([date])
  @@index([rank])
}

// User profile extension for verification
model UserProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  aadhaarNumber    String?
  aadhaarVerified  Boolean   @default(false)
  panNumber        String?
  panVerified      Boolean   @default(false)
  verificationData Json?     // Store encrypted verification details
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([aadhaarNumber])
  @@index([panNumber])
}

// Verification attempt tracking
model VerificationAttempt {
  id               String    @id @default(cuid())
  userId           String
  verificationType String    // 'aadhaar', 'pan', etc.
  status           String    // 'pending', 'success', 'failed'
  errorMessage     String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([verificationType])
  @@index([status])
  @@index([createdAt])
}
