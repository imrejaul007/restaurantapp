{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "src/**/*.(t|j)s",
    "!src/main.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.interface.ts",
    "!src/**/*.dto.ts",
    "!src/**/*.entity.ts",
    "!src/**/*.module.ts"
  ],
  "coverageDirectory": "./coverage/e2e",
  "coverageReporters": ["html", "text", "lcov"],
  "setupFilesAfterEnv": ["<rootDir>/test/setup.ts"],
  "testTimeout": 60000,
  "maxWorkers": 1,
  "detectOpenHandles": true,
  "forceExit": true,
  "verbose": true
}