# Database
DATABASE_URL="postgresql://username:password@localhost:5432/restaurant_saas?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-here-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=8000
NODE_ENV="development"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# AWS S3 (for file uploads)
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET_NAME="restaurant-saas-uploads"

# Razorpay (for payments)
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# UIDAI/Aadhaar API (for verification)
UIDAI_API_KEY="your-uidai-api-key"
UIDAI_BASE_URL="https://uidai.gov.in/api"

# Email Service (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Redis (for caching - optional)
REDIS_URL="redis://localhost:6379"